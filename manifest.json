{
  "manifest_version": 3,
  "name": "YouUtility - Pin Player",
  "version": "1.0",
  "description": "YouTubeの動画プレイヤーを画面右上に固定します。",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_title": "プレイヤーを固定/解除"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
