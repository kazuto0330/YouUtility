{
  "manifest_version": 3,
  "name": "YouUtility - Pin Player",
  "version": "1.0.0",
  "description": "YouTubeの動画プレイヤーをスクロール時に画面端に固定し、ながら見を快適にする拡張機能。",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_title": "YouUtility 設定を開く"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}